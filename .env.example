# ─── App ──────────────────────────────────────────────────────────────────────
DEBUG=false

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://prepuser:preppass@localhost:5432/prepdb
DATABASE_SYNC_URL=postgresql://prepuser:preppass@localhost:5432/prepdb

# ─── Redis ────────────────────────────────────────────────────────────────────
# Used for: session state cache, grading status tracking, RQ job broker
REDIS_URL=redis://localhost:6379/0

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=change-me-in-production

# ─── Google Gemini (Required) ─────────────────────────────────────────────────
# Used for: test generation (MCQs + coding problems) and post-test AI feedback
# Get your key at: https://aistudio.google.com/app/apikey
# Model used: gemini-flash-lite-latest
GEMINI_API_KEY=your-gemini-api-key-here

# ─── Frontend ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000

# ─── Code Execution ───────────────────────────────────────────────────────────
# Piston API is used for code execution (free, no key needed).
# Judge0 keys below are reserved for future use only.
# JUDGE0_URL=https://judge0-ce.p.rapidapi.com
# JUDGE0_API_KEY=your-rapidapi-key
# JUDGE0_HOST=judge0-ce.p.rapidapi.com
